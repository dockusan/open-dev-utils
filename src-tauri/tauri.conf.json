{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenDevUtils",
  "version": "0.1.0",
  "identifier": "com.cflstudio.opendevutils",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenDevUtils",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2NkY3QTNCQjNGNEFFM0IKUldRN3J2U3pPM3B2aHFjZTBkVUdtanRCcTExUGxkTzhHRmU1QnM1MDljZjdVWk9BekdON2EvalUK",
      "endpoints": [
        "https://github.com/cflstudio/opendevutils/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
